# ══════════════════════════════════════════════════════════════════
#  YouTube Shorts Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── Runway ML ──────────────────────────────────────────────────────
# Get your API key at: https://app.runwayml.com/settings/api-keys
RUNWAY_API_KEY=your_runway_api_key_here

# Runway API base URL (leave as default unless you have a custom endpoint)
RUNWAY_API_BASE=https://api.dev.runwayml.com/v1

# ── YouTube Data API ────────────────────────────────────────────────
# Path to client_secrets.json downloaded from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client ID → Download JSON)
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# Path where the token will be saved after first login
YOUTUBE_TOKEN_FILE=youtube_token.json

# Refresh token obtained by running get_youtube_token.py once locally.
# Required for non-interactive environments (Railway, Docker, CI).
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# Channel ID of the TARGET YouTube channel (safety check before every upload).
# Find it at: youtube.com/channel/<ID> or via get_youtube_token.py output.
# If set, upload.py will REFUSE to post if authenticated on a different channel.
YOUTUBE_CHANNEL_ID=your_channel_id_here

# ── Video Settings ─────────────────────────────────────────────────
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
SHORT_MIN_DURATION=5
SHORT_MAX_DURATION=60

# ── Runway Generation ──────────────────────────────────────────────
# NOTE: RUNWAY_CLIPS_PER_SHORT and RUNWAY_CLIP_DURATION are hardcoded in config.py
# (1 clip × 5s = 125 credits/run). Do NOT set them here — Railway env vars were
# overriding the code defaults causing 4 clips to be generated instead of 1.

# Warn if cumulative credits used exceed this threshold
RUNWAY_MIN_CREDITS=75

# ── Telegram Notifications (optional) ─────────────────────────────
# Leave empty to disable Telegram alerts.
# Create a bot at t.me/BotFather, get the token, then start a chat
# and run: https://api.telegram.org/bot<TOKEN>/getUpdates to find chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
